# ============================================
# 输出文件配置区
# ============================================
# 通用数据存储子目录（相对于 data/，可为空，不允许绝对路径和场景保留名）
IP_STORAGE_DIR=
# 通用数据存储文件名（用于数据文件命名前缀）
IP_STORAGE_NAME=ip_data
# IP域名反查流水线项目名称（输出到 data/ip_domain_lookup/{项目名称}/）
IP_IP_DOMAIN_LOOKUP_PROJECT_NAME=temp
# 溯源IP处理流水线项目名称（输出到 data/trace_ip/{项目名称}/）
IP_TRACE_IP_PROJECT_NAME=temp

# ============================================
# API Key / Cookie 凭证配置区
# ============================================
# Fofa API Key
IP_FOFA_API_KEY=your_fofa_api_key_here
# IPInfo Access Token
IP_IPINFO_ACCESS_TOKEN=your_ipinfo_access_token_here
# 爱站网 Cookie（浏览器登录后获取）
IP_AIZHAN_COOKIE=your_aizhan_cookie_here
# 站长之家 Cookie（可选，有 Cookie 可查更多信息）
IP_CHINAZ_COOKIE=your_chinaz_cookie_here
# ZoomEye API Key
IP_ZOOMEYE_API_KEY=your_zoomeye_api_key_here

# ============================================
# 查询间隔与超时配置区
# ============================================
# Fofa 查询超时（秒）
IP_FOFA_QUERY_TIMEOUT=30
# Fofa API Key 验证超时（秒）
IP_FOFA_VALIDATE_TIMEOUT=10
# Fofa 查询间隔（秒）
IP_FOFA_QUERY_DELAY=1.1
# IPInfo 查询超时（秒）
IP_IPINFO_QUERY_TIMEOUT=30
# IPInfo API 验证超时（秒）
IP_IPINFO_VALIDATE_TIMEOUT=30
# IPInfo 查询间隔（秒）
IP_IPINFO_QUERY_DELAY=1.1
# RDNS 查询间隔（秒）
IP_RDNS_QUERY_DELAY=0.1
# RDNS 查询超时（秒）
IP_RDNS_QUERY_TIMEOUT=1.5
# Whois 查询间隔（秒）
IP_WHOIS_QUERY_DELAY=0.5
# Whois 查询超时（秒）
IP_WHOIS_QUERY_TIMEOUT=2
# 爱站查询超时（秒）
IP_AIZHAN_QUERY_TIMEOUT=15
# 爱站 Cookie 验证超时（秒）
IP_AIZHAN_VALIDATE_TIMEOUT=10
# 爱站查询间隔（秒）
IP_AIZHAN_QUERY_DELAY=2
# 站长之家查询超时（秒）
IP_CHINAZ_QUERY_TIMEOUT=15
# 站长之家 Cookie 验证超时（秒）
IP_CHINAZ_VALIDATE_TIMEOUT=10
# 站长之家查询间隔（秒）
IP_CHINAZ_QUERY_DELAY=2
# ZoomEye 查询超时（秒）
IP_ZOOMEYE_QUERY_TIMEOUT=30
# ZoomEye 查询间隔（秒）
IP_ZOOMEYE_QUERY_DELAY=1
# SSL 证书获取端口
IP_SSL_CERT_PORT=443
# SSL 连接超时（秒）
IP_SSL_CERT_TIMEOUT=5
# SSL OpenSSL 子进程超时（秒）
IP_SSL_CERT_OPENSSL_TIMEOUT=10
# SSL 证书查询间隔（秒）
IP_SSL_CERT_QUERY_DELAY=0.5

# ============================================
# IP域名反查流水线 - 渠道开关配置区
# ============================================
# 设置为 true 启用，false 禁用，默认全部启用
# 启用 RDNS PTR 反向解析
IP_IP_DOMAIN_LOOKUP_RDNS_PTR_ENABLED=true
# 启用爱站网 IP 反查域名
IP_IP_DOMAIN_LOOKUP_AIZHAN_ENABLED=true
# 启用站长之家 IP 反查域名
IP_IP_DOMAIN_LOOKUP_CHINAZ_ENABLED=true
# 启用 ZoomEye 网络空间测绘
IP_IP_DOMAIN_LOOKUP_ZOOMEYE_ENABLED=true
# 启用 Fofa 搜索查询
IP_IP_DOMAIN_LOOKUP_FOFA_SEARCH_ENABLED=true
# 启用 SSL 证书域名提取
IP_IP_DOMAIN_LOOKUP_SSL_CERT_ENABLED=true

# ============================================
# 溯源IP处理流水线 - 渠道开关配置区
# ============================================
# 设置为 true 启用，false 禁用，默认全部启用
# 阶段1：基础情报采集
# 启用 IPInfo 查询
IP_TRACE_IP_PHASE1_IPINFO_ENABLED=true
# 启用 RDNS PTR 反向解析
IP_TRACE_IP_PHASE1_RDNS_PTR_ENABLED=true
# 阶段3：深度查询
# 启用爱站网 IP 反查域名
IP_TRACE_IP_PHASE3_AIZHAN_ENABLED=true
# 启用站长之家 IP 反查域名
IP_TRACE_IP_PHASE3_CHINAZ_ENABLED=true
# 启用 Fofa Host 聚合查询
IP_TRACE_IP_PHASE3_FOFA_HOST_ENABLED=true

# ============================================
# IP标签打标工具 - 配置区
# ============================================
# 标签配置文件目录（默认 config/ip_tagger）
IP_TAGGER_CONFIG_DIR=config/ip_tagger
